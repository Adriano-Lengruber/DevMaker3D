# DevMaker3D - Environment Variables Example

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=DevMaker3D
NEXT_PUBLIC_SITE_DESCRIPTION="Impressão 3D com rigor de engenharia e alma de artista"

# Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=contato@devmaker3d.com.br
RESEND_TO_EMAIL=adriano@devmaker3d.com.br

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Forms Configuration
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=/api/contact

# Social Media
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/devmaker3d
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/devmaker3d
NEXT_PUBLIC_WHATSAPP_NUMBER=5522999999999

# Business Information
NEXT_PUBLIC_BUSINESS_ADDRESS="Rua Principal, 123 - Centro, Itaperuna/RJ"
NEXT_PUBLIC_BUSINESS_PHONE="(22) 99999-9999"
NEXT_PUBLIC_BUSINESS_EMAIL="contato@devmaker3d.com.br"
NEXT_PUBLIC_BUSINESS_CNPJ="00.000.000/0001-00"

# File Upload Configuration
MAX_FILE_SIZE=10485760 # 10MB in bytes
ALLOWED_FILE_TYPES=.stl,.obj,.3mf,.step,.stp

# Security
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=10

# Development
DEBUG=false
NODE_ENV=development